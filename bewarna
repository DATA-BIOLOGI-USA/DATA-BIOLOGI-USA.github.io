<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Arsip Digital Praktikum Biologi</title>
    <style>
        /* Desain Latar Belakang */
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f2f7f4; /* Warna abu-abu kehijauan lembut */
            color: #2c3e50;
            margin: 0;
            padding: 20px 15px;
            display: flex;
            justify-content: center;
        }

        /* Kotak Pembungkus Konten Utama */
        .container {
            max-width: 600px;
            width: 100%;
            background: #ffffff; /* Kotak putih bersih */
            padding: 25px;
            border-radius: 16px; /* Sudut melengkung halus */
            box-shadow: 0 4px 20px rgba(0,0,0,0.06); /* Efek bayangan tipis */
            box-sizing: border-box;
        }

        /* Desain Judul Utama */
        h1 {
            color: #1b5e20; /* Hijau tua khas tumbuhan/biologi */
            font-size: 24px;
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            text-align: center;
        }

        .subtitle {
            color: #7f8c8d;
            text-align: center;
            margin-top: 0;
            margin-bottom: 25px;
            font-size: 13px;
            font-style: italic;
        }

        h2 {
            color: #2e7d32;
            border-bottom: 2px solid #c8e6c9;
            padding-bottom: 8px;
            font-size: 18px;
            margin-top: 20px;
        }

        /* Struktur Daftar Laporan */
        ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        li {
            background: #fafdfa;
            margin-bottom: 12px;
            padding: 16px;
            border-left: 5px solid #2e7d32; /* Garis hijau di samping */
            border-radius: 6px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        li strong {
            font-size: 15px;
            color: #2c3e50;
            padding-right: 10px;
        }

        /* Desain Tombol Lihat PDF */
        .btn-pdf {
            text-decoration: none;
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
            white-space: nowrap;
            transition: all 0.2s ease;
            background-color: #e8f5e9;
            color: #2e7d32;
            border: 1px solid #c8e6c9;
        }

        /* Efek ketika tombol disentuh kursor/jari */
        .btn-pdf:hover {
            background-color: #2e7d32;
            color: white;
        }

        /* Tombol nonaktif untuk laporan yang belum ada */
        .disabled {
            background-color: #eceff1;
            color: #b0bec5;
            border: 1px solid #cfd8dc;
            cursor: not-allowed;
        }

        footer {
            text-align: center;
            margin-top: 35px;
            color: #b2bec3;
            font-size: 11px;
            border-top: 1px dashed #e0e0e0;
            padding-top: 15px;
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>Biology Digital Archive</h1>
        <p class="subtitle">Perpustakaan digital praktikum & portofolio ilmiah saya</p>

        <h2>📂 Daftar Laporan Praktikum - Semester 2</h2>
        
        <ul>
            <li>
                <strong>Ekologi Terestrial</strong> 
                <!-- Klik tombol ini langsung membuka PDF di tab baru -->
                <a href="dokumen/laporan-ekologi.pdf" class="btn-pdf" target="_blank">Lihat PDF</a>
            </li>
            
            <li>
                <strong>Mikrobiologi - Pewarnaan Gram</strong> 
                <a href="#" class="btn-pdf disabled">Belum Tersedia</a>
            </li>
            
            <li>
                <strong>Fisiologi Tumbuhan - Fotosintesis</strong> 
                <a href="#" class="btn-pdf disabled">Belum Tersedia</a>
            </li>
        </ul>

        <footer>
            <p>Website diperbarui berkala • © 2026</p>
        </footer>
    </div>

</body>
</html>
